# ---------------------------------------------------------------------------
# Agent Sandbox — Environment Variables
# Copy this file to .env and fill in your values before starting.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# ---- Core sandbox --------------------------------------------------------

# VNC password for direct VNC access (port 5900)
VNC_PASSWORD=sandbox

# Host port overrides (optional — defaults shown)
# NGINX_PORT=8080
# VNC_PORT=5900
# NOVNC_PORT=6080
# MCP_PORT=8079
# API_PORT=8091
# CDP_PORT=9222

# ---- AI / Anthropic -------------------------------------------------------

# Required for the sms module (Claude API calls)
ANTHROPIC_API_KEY=

# ---- SMS / WhatsApp module ------------------------------------------------

# Phone number or chat ID to forward Claude's replies to
WHATSAPP_RECIPIENT=

# URL that the sms module POSTs WhatsApp messages to
# Default points to a local bot/bridge running inside the sandbox network
SMS_WEBHOOK_URL=http://host.docker.internal:8100/sms

# URL of your WhatsApp send endpoint (Cloud API, Twilio, wa-automate, etc.)
# Body sent: { "to": "<WHATSAPP_RECIPIENT>", "message": "<text>" }
# WHATSAPP_WEBHOOK_URL=http://localhost:8200/whatsapp/send

# ---- Android module -------------------------------------------------------

# Device profile name (see budtmo/docker-android for available profiles)
ANDROID_DEVICE=Samsung Galaxy S10

# Host port for ADB over TCP
# ANDROID_ADB_PORT=5555

# Host port for the Android noVNC view
# ANDROID_NOVNC_PORT=6081
